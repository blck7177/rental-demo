{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "listing_record.schema.json",
  "title": "NYC Rental Listing Record",
  "description": "A structured record of a single NYC apartment rental listing",
  "type": "object",
  "required": [
    "listing_id",
    "url",
    "source",
    "price_monthly",
    "bedrooms",
    "borough",
    "fetched_at",
    "run_id"
  ],
  "properties": {
    "listing_id": {
      "type": "string",
      "pattern": "^lst_[a-f0-9]{16}$",
      "description": "Unique ID: 'lst_' + first 16 hex chars of SHA-256 of URL"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Original listing page URL"
    },
    "source": {
      "type": "string",
      "description": "Source website domain, e.g. 'streeteasy.com'"
    },
    "price_monthly": {
      "type": "integer",
      "minimum": 500,
      "maximum": 50000,
      "description": "Monthly rent in USD"
    },
    "bedrooms": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "Number of bedrooms; 0 = studio"
    },
    "borough": {
      "type": "string",
      "enum": ["Manhattan", "Brooklyn", "Queens", "Bronx", "Staten Island"],
      "description": "NYC borough"
    },
    "fetched_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the page was fetched"
    },
    "run_id": {
      "type": "string",
      "description": "ID of the discovery run that created this record"
    },
    "address": {
      "type": ["string", "null"],
      "description": "Full address, e.g. '350 West 42nd Street, New York, NY 10036'"
    },
    "neighborhood": {
      "type": ["string", "null"],
      "description": "Neighborhood name, e.g. 'Upper West Side'"
    },
    "bathrooms": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 10,
      "description": "Number of bathrooms"
    },
    "sq_ft": {
      "type": ["integer", "null"],
      "minimum": 50,
      "maximum": 20000,
      "description": "Square footage"
    },
    "available_date": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Available move-in date in YYYY-MM-DD format"
    },
    "listing_date": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date listing was published in YYYY-MM-DD format"
    },
    "description_snippet": {
      "type": ["string", "null"],
      "maxLength": 500,
      "description": "Short description excerpt, max 500 characters"
    },
    "amenities": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      },
      "description": "List of amenities, e.g. ['gym', 'doorman', 'laundry in unit']"
    },
    "pet_policy": {
      "type": ["string", "null"],
      "enum": ["pets_allowed", "no_pets", "cats_only", "dogs_ok_small", "dogs_ok", "case_by_case", "unknown", null],
      "description": "Pet policy"
    },
    "laundry": {
      "type": ["string", "null"],
      "enum": ["in_unit", "in_building", "none", "unknown", null],
      "description": "Laundry situation"
    },
    "doorman": {
      "type": ["boolean", "null"],
      "description": "Whether the building has a doorman"
    },
    "elevator": {
      "type": ["boolean", "null"],
      "description": "Whether the building has an elevator"
    },
    "no_fee": {
      "type": ["boolean", "null"],
      "description": "Whether this is a no broker fee listing"
    },
    "listing_type": {
      "type": ["string", "null"],
      "enum": ["apartment", "studio", "condo", "co-op", "townhouse", "loft", "other", null],
      "description": "Type of rental unit"
    },
    "floor": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 200,
      "description": "Floor number"
    },
    "quality_tier": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Data quality tier based on field completeness"
    },
    "raw_listing_path": {
      "type": ["string", "null"],
      "description": "Relative path to raw HTML file within runs/ directory"
    },
    "status": {
      "type": "string",
      "enum": ["active", "expired", "unknown"],
      "default": "active",
      "description": "Listing status"
    },
    "structured_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp when structured extraction completed"
    }
  },
  "additionalProperties": false
}
