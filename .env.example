# LLM API Keys (at least one required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Model preferences
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
OPENAI_MODEL=gpt-4o-mini

# App settings
DEMO_MODE=true

# Host ports for local Docker Compose (mapped to container ports 8000/3000)
API_HOST_PORT=8102
WEB_HOST_PORT=3102

# Frontend API URL (used by browser in Docker mode; leave empty for manual dev with Next.js proxy)
NEXT_PUBLIC_API_URL=http://localhost:8102

# CORS origins (comma-separated; used by FastAPI when running in Docker)
CORS_ORIGINS=http://localhost:3102,http://127.0.0.1:3102

# WeCom webhook (optional, for push notifications)
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY

# Google Places API (optional, for review research)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
